#!/usr/bin/env bash
#
# prepare-windows-image — build the pristine Win11-ARM base VM that Mactions'
# WindowsVMProvider clones (throwaway) per job.
#
# You can supply the official Windows 11 ARM64 ISO yourself (--iso), or omit it
# and let this script AUTO-RESOLVE + download the LATEST Win11 ARM64 retail build
# via UUP dump (the only automatable source — Microsoft only offers the ISO as a
# time-limited interactive download, so it can't be hard-coded). Everything else
# (the autounattend answer file, the bootstrap ISO, the guided install) this
# script sets up for you.
#
# Auto-download path needs a few brew-installable converter tools (aria2c,
# cabextract, wimlib-imagex, mkisofs, chntpw); the script checks for them and
# prints an exact `brew install …` line if any are missing.
#
# After this finishes you'll have a powered-off VM named (by default)
# "win11-runner-base". Point Mactions' WindowsVMProviderFactory at that name.
#
# Scope: on VMware Fusion the whole base build is automated end to end (this
# downloads/remasters the ISO, then fusion-windows-base authors the .vmx, boots
# headless, lets autounattend + bootstrap run, and snapshots base-provisioned).
# The per-job clone/boot/destroy loop afterward is fully automated by the provider.
#
# Usage:
#   scripts/prepare-windows-image [--iso /path/to/Win11_ARM64.iso] [options]
#
# Options:
#   --iso PATH        Path to an official Win11 ARM64 ISO. OPTIONAL — if omitted,
#                     the latest Win11 ARM64 retail build is auto-downloaded via
#                     UUP dump and converted to an ISO.
#   --name NAME       Base VM name to create (default: win11-runner-base).
#   --tool TOOL       fusion   (default: auto-detect; VMware Fusion is the only
#                     backend — the proven Win11-ARM path).
#   --disk GB         Guest disk size in GB (default: 64).
#   --ram MB          Guest RAM in MB (default: 8192).
#   --cpus N          Guest vCPU count (default: 4).
#   --updates 0|1     0 (default) = clean GA RTM ISO; 1 = fold the latest
#                     cumulative into install.wim (fully patched, but a
#                     mixed-build boot chain — see the note by UPDATES below).
#   -h, --help        Show this help.

set -euo pipefail

NAME="win11-runner-base"
TOOL=""
ISO=""
DISK_GB=64
RAM_MB=8192
CPUS=4
# UUP dump's `updates` flag — when 1 the latest cumulative is FOLDED into the
# ISO's install.wim, which gives a fully patched install but produces a
# MIXED-BUILD bootloader (boot files from the RTM base + kernel from the
# cumulative). That mismatch can hang Microsoft's `bootmgr` infinitely under
# QEMU. `updates=0` produces a clean GA RTM ISO — slightly older patch level
# but a boot chain that's internally consistent. Default flipped to 0 here.
UPDATES=0
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() { sed -n '2,42p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'; }

while [[ $# -gt 0 ]]; do
  case "$1" in
    --iso)  ISO="$2"; shift 2 ;;
    --name) NAME="$2"; shift 2 ;;
    --tool) TOOL="$2"; shift 2 ;;
    --disk) DISK_GB="$2"; shift 2 ;;
    --ram)  RAM_MB="$2"; shift 2 ;;
    --cpus) CPUS="$2"; shift 2 ;;
    --updates) UPDATES="$2"; shift 2 ;;  # 0 = clean RTM, 1 = include latest cumulative
    -h|--help) usage; exit 0 ;;
    *) echo "unknown option: $1" >&2; usage; exit 2 ;;
  esac
done

die() { echo "error: $*" >&2; exit 1; }

# --- Temp cleanup (success OR failure) ---------------------------------------
# The small scratch that should ALWAYS be reaped on exit (incl. die / set -e /
# SIGINT): the unattend staging dir and the no-prompt-ISO mountpoint. Tracked in
# globals so the EXIT trap can reap them regardless of how we leave.
#
# NOTE: the multi-GB UUP download is DELIBERATELY NOT reaped here — it lives in a
# persistent per-build cache ($CACHE_ROOT/uup-<build>) so an interrupted run
# RESUMES it (aria2 -c) instead of re-downloading ~8 GB. That cache is reclaimed
# only after a fully-successful build (see the fusion arm). The canonical
# artifacts (~/.mactions/win11-base.iso etc.) are written before exit, so reaping
# the staging/mount scratch is always safe.
UNATTEND_STAGING=""  # build_unattend_iso: autounattend.xml + bootstrap.ps1 stage
NOPROMPT_MNT=""      # make_noprompt_iso: read-only DMG mountpoint of the Win11 ISO
cleanup_temp() {
  [[ -n "$NOPROMPT_MNT" && -d "$NOPROMPT_MNT" ]] && {
    hdiutil detach "$NOPROMPT_MNT" >/dev/null 2>&1 || true
    rmdir "$NOPROMPT_MNT" 2>/dev/null || true
  }
  [[ -n "$UNATTEND_STAGING" ]] && rm -rf "$UNATTEND_STAGING" 2>/dev/null || true
}
trap cleanup_temp EXIT

# --- Detect the hypervisor CLI ----------------------------------------------
# VMware Fusion (free since Nov 2024) is the sole backend — the PROVEN Win11-ARM
# path on Apple Silicon. It is NOT brew-installable (Broadcom-portal download),
# so we only detect its presence.
detect_tool() {
  local VMRUN="/Applications/VMware Fusion.app/Contents/Library/vmrun"
  if [[ -x "$VMRUN" ]]; then echo fusion; return; fi
  echo none
}
[[ -z "$TOOL" ]] && TOOL="$(detect_tool)"

if [[ "$TOOL" == "none" ]]; then
  cat <<'EOF' >&2
VMware Fusion not found — it's the backend Mactions uses for Win11-ARM.

Install VMware Fusion (free, and the PROVEN Win11-ARM backend; see AGENTS.md):
  Download + install VMware Fusion from the Broadcom portal. It is NOT
  brew-installable. Then re-run this script — it auto-detects Fusion.
EOF
  exit 1
fi

# Fusion is the SOLE backend (QEMU/UTM/Parallels were removed). An explicit
# --tool value bypasses both auto-detect and the `none` guard above, and the
# dispatch `case "$TOOL"` near the end has only a `fusion` arm — so any other
# value (e.g. `--tool qemu`, or a casing typo `--tool Fusion`) would run the full
# multi-GB ISO download + remaster and then match nothing, printing "Done" while
# NO base VM was built. Reject it LOUDLY here, before any of that work.
[[ "$TOOL" == "fusion" ]] \
  || die "unsupported --tool '$TOOL' — VMware Fusion is the only backend (use --tool fusion, or omit it to auto-detect)."

# --- Resolve the ISO: user-supplied, or auto-download the latest -------------
# UUP dump JSON API: list arm64 builds newest-first, take the first, fetch the
# download package + run its convert script to produce an ISO. This is the only
# automatable source for the official media (Microsoft's own ISO is a manual,
# time-limited interactive download).
UUP_API="https://api.uupdump.net"   # JSON list endpoints (listid.php / listeditions.php)
UUP_WWW="https://uupdump.net"        # autodl=2 convert ZIP is front-end-only; the api host 400s UNSUPPORTED_COMBINATION
RECORDED_BUILD=""

# Provisioning-recipe version baked into the base by bootstrap.ps1. BUMP this
# whenever a bootstrap.ps1 change makes an ALREADY-BUILT base functionally stale
# (e.g. the MinGit->PortableGit switch that added bash). Do NOT bump for
# comment/whitespace-only edits. This is the AUTHORITY: it's stamped into
# ~/.mactions/windows-base.recipe on a successful build, and MUST stay equal to
# WindowsImage.currentProvisioningRecipeVersion (a unit test enforces that), which
# the app reads to decide whether a built base needs a rebuild.
# v13: three hosted-parity OS-semantic fixes, all sentinel-verified: Git moves
# to C:\Program Files\Git with the full hosted machine-PATH composition - \cmd,
# the mingw \bin (clangarm64 on ARM64), \usr\bin (PathOption=CmdTools adds all
# three on hosted; usr\bin makes sed/awk/grep resolve from pwsh/cmd steps) plus
# \bin (Install-Git.ps1's Add-MachinePathItem); UAC mirrors hosted exactly
# (ConsentPromptBehaviorAdmin=0, EnableLUA stays 1 - the MactionsRunOnce task's
# -RunLevel Highest supplies the full admin token, and UWP/MSIX launches work
# again); time zone set to UTC (hosted/Azure default).
# v12: bootstrap.ps1 no longer installs 7-Zip (BASE.md decision test: a
# convenience tool, not a runner/OS semantic; the old install was pinned to a
# 404-able URL, non-fatal, and off PATH). Workflows install it themselves; see
# PARITY.md.
# v11: bootstrap.ps1 bakes hosted-parity runner-IDENTITY env at Machine scope
# (issue #37 V2): ImageOS=win25 (latest whitelist-safe Server proxy for the
# Win11-ARM base; GitHub has no win11/ARM token and a bad value hard-fails
# whitelist-checking setup-* actions) + RUNNER_TOOL_CACHE=AGENT_TOOLSDIRECTORY=
# C:\hostedtoolcache\windows. Sentinel-verified before the base snapshots.
# v10: bootstrap.ps1 keeps hosted Windows Defender parity best-effort so Win11
# ARM builds do not fail when Defender immediately remediates/verifies some
# preferences as unchanged; PortableGit temp SFX files use unique names to avoid
# stale lock failures.
# v9: bootstrap.ps1 mirrors hosted Windows Defender scan/monitoring disablement,
# C:/D: exclusions, and the Win11-ARM BlockAtFirstSeen exception from
# actions/runner-images' Configure-WindowsDefender.ps1.
# v8: bootstrap.ps1 disables Windows Update by policy/service and telemetry
# policy, matching hosted-image determinism without disabling the root scheduled
# task path that MactionsRunOnce needs.
# v7: bootstrap.ps1 mirrors hosted Git post-install behavior: system
# safe.directory "*", GCM_INTERACTIVE=Never, and seeded SSH known_hosts.
# v6: bootstrap.ps1 enables the OS-level LongPathsEnabled registry switch,
# matching GitHub-hosted Windows images for post-checkout deep-path tooling.
# v5: bootstrap.ps1 sets LocalMachine execution policy to Unrestricted, matching
# GitHub-hosted Windows images so explicit `shell: powershell` steps can run.
# v4: bootstrap.ps1 verifies git/bash/pwsh before the sentinel (+ retries their
# downloads). v3 bases can be silently missing those tools (a swallowed transient
# download failure still snapshotted), so they warrant a rebuild to a verified v4.
PROVISIONING_RECIPE_VERSION=13

# Fetch a UUP dump URL with backoff, writing the body to OUTFILE. Retries on
# network errors, HTTP 429 (UUP dump's ~20-25s per-IP throttle), and 5xx; fails
# fast on other 4xx (e.g. a permanent 400). Progress goes to stderr so callers
# capturing stdout stay clean.
uup_curl() {                       # uup_curl OUTFILE URL [extra curl args...]
  local out="$1" url="$2"; shift 2
  local delay=5 attempt code
  for attempt in 1 2 3 4 5; do
    code="$(curl -sSL -o "$out" -w '%{http_code}' "$@" "$url" 2>/dev/null)" || code="000"
    case "$code" in
      2??) return 0 ;;
      429 | 5?? | 000) : ;;                                  # transient -> retry
      *) echo "    UUP request failed (HTTP $code), not retryable" >&2; return 1 ;;
    esac
    echo "    UUP request failed (attempt $attempt/5, HTTP $code); retrying in ${delay}s..." >&2
    sleep "$delay"; delay=$((delay < 30 ? delay * 2 : 30))   # cap >observed throttle window
  done
  return 1
}

require_converter_deps() {
  # Mirrors WindowsImage.converterDependencies in MactionsCore. The upstream
  # convert.sh hard-requires ALL of these. Map binary -> brew formula: aria2c
  # ships in `aria2`, wimlib-imagex in `wimlib`, mkisofs in `cdrtools`, and
  # chntpw isn't in homebrew-core (the minacle tap has a native-arm64 build;
  # `brew install` auto-taps it).
  local -a bins=(aria2c cabextract wimlib-imagex mkisofs chntpw)
  local -a missing=()
  for b in "${bins[@]}"; do
    command -v "$b" >/dev/null 2>&1 || {
      case "$b" in
        aria2c) missing+=("aria2") ;;
        wimlib-imagex) missing+=("wimlib") ;;
        mkisofs) missing+=("cdrtools") ;;
        chntpw) missing+=("minacle/chntpw/chntpw") ;;
        *) missing+=("$b") ;;
      esac
    }
  done
  if [[ ${#missing[@]} -gt 0 ]]; then
    # chntpw resolves to a third-party tap (minacle/chntpw), not homebrew-core.
    # Homebrew 5.2/6.0 makes tap-trust checks the default, at which point a bare
    # `brew install minacle/chntpw/chntpw` is ignored until the tap is trusted
    # once — so surface that step for any user/tap/formula in the missing list.
    local trust_hint=""
    for m in "${missing[@]}"; do
      [[ "$m" == */*/* ]] || continue
      trust_hint+="
On Homebrew 5.2+/6.0+, \`$m\` is from a third-party tap and must be trusted once:
  brew tap ${m%/*} && brew trust --formula $m"
    done
    die "auto-download needs these tools first:
  brew install ${missing[*]}${trust_hint}
Or supply your own ISO with --iso /path/to/Win11_ARM64.iso (skips the converter)."
  fi
}

auto_download_iso() {
  command -v curl   >/dev/null 2>&1 || die "curl is required to query UUP dump."
  command -v python3 >/dev/null 2>&1 || die "python3 is required to parse the UUP dump JSON."
  require_converter_deps

  echo "==> Resolving the latest stable GA Windows 11 ARM64 build from UUP dump" >&2
  local listing uuid build resolved
  listing="$(mktemp)"
  uup_curl "$listing" "$UUP_API/listid.php?search=Windows%2011%20arm64&sortByDate=1" \
    || die "couldn't reach the UUP dump API after retries ($UUP_API)."
  # listid.php returns response.builds as an OBJECT keyed by stringified ints
  # (NOT an array), mixing channels — the newest rows are usually Insider/canary/
  # preview. Walk the dict VALUES, keep clean GA arm64 feature updates on a
  # known-GA major, and pick the highest build NUMERICALLY. Mirrors
  # WindowsImage.selectLatestGA in MactionsCore (keep the two in sync).
  # NOTE: capture via $(...) — NOT `read < <(python3 … <<'PY')`. macOS ships bash
  # 3.2, which mis-parses a heredoc nested inside `<(…)` process substitution
  # ("ambiguous redirect" + garbled stdin). Plain command substitution is safe.
  resolved="$(python3 - "$listing" <<'PY'
import json, sys
try:
    with open(sys.argv[1]) as f:
        data = json.load(f)
except Exception:
    sys.exit("could not parse UUP dump JSON")

raw = (data.get("response") or {}).get("builds")
# Real API: builds is a DICT keyed by stringified ints. Tolerate a list too.
rows = list(raw.values()) if isinstance(raw, dict) else (raw if isinstance(raw, list) else [])

ALLOWED_MAJORS = {22000, 22621, 22631, 26100, 26200}  # known-shipped GA majors; bump when a new HNN GAs
EXCLUDE = ("insider", "preview update", "cumulative update", ".net framework",
           "feature update to windows", "oobe update", "security update",
           "update for windows 11 (")

def ver(b):
    # Split on '.' (NOT a digit-run regex) so this agrees with Swift's
    # WindowsImage.compareBuilds for the well-formed major.minor build strings UUP
    # actually emits (e.g. "26100.1742"). (The old re.findall(r"\d+") also pulled
    # digits out of any trailing parenthetical noise.) NOTE: this isn't byte-for-
    # byte identical to Swift for DEGENERATE inputs — Swift keeps a non-numeric
    # segment as 0 (Int($0) ?? 0) whereas this drops it — but such build strings
    # never occur in the GA listing, so selection is unaffected.
    return tuple(int(x) for x in str(b or "").split(".") if x.isdigit())

best = None  # (sortkey, uuid, build)
for r in rows:
    if not isinstance(r, dict):
        continue
    if str(r.get("arch", "")).lower() != "arm64":
        continue
    title = str(r.get("title", "")).lower()
    if "windows 11, version " not in title or any(x in title for x in EXCLUDE):
        continue
    v = ver(r.get("build", ""))
    if not v or v[0] not in ALLOWED_MAJORS:
        continue
    uuid = str(r.get("uuid", "")).strip()
    if not uuid:
        continue
    key = (v, int(r.get("created") or 0))
    if best is None or key > best[0]:
        best = (key, uuid, str(r.get("build", "")))

if best is None:
    sys.exit("no stable GA Win11 ARM64 build found in the UUP dump listing")
print(best[1], best[2])
PY
)" || { rm -f "$listing"; die "no stable GA Win11 ARM64 build found in the UUP dump listing."; }
  rm -f "$listing"
  uuid="${resolved%% *}"     # everything before the first space
  build="${resolved##* }"    # everything after the last space
  [[ -n "$uuid" ]] || die "no stable GA Win11 ARM64 build found in the UUP dump listing."
  RECORDED_BUILD="$build"
  echo "    build $build  (uuid $uuid)" >&2

  # RESUME: if a no-prompt boot ISO for THIS build is already cached, skip the
  # whole ~8 GB download + convert + remaster. A retry after an interrupted
  # install then jumps straight to the VM build (the "continue on the latest
  # step" win). The cache + its build/no-prompt tags are written only on a
  # successful remaster below, so a stale/partial/prompting ISO can't be
  # mistaken for a finished one.
  if [[ -f "$ISO_CACHE" \
        && "$(cat "$ISO_BUILD_MARKER" 2>/dev/null)" == "$build" \
        && "$(cat "$ISO_NOPROMPT_MARKER" 2>/dev/null)" == "$build" ]]; then
    echo "==> Reusing cached Win11 ISO for build $build (resumed — skipping the ~8 GB download/convert)" >&2
    ISO="$ISO_CACHE"
    NEED_REMASTER=0
    return
  fi

  # Persistent per-build download dir (NOT the EXIT-trap temp): the converter runs
  # aria2 with -c (continue), so an interrupted download resumes from the partial
  # UUPs/ here across runs / network drops instead of restarting. Drop any OTHER
  # build's stale cache so only one ever sits on disk; this whole dir is reaped on
  # a fully-successful build (see the fusion arm).
  local workdir="$CACHE_ROOT/uup-$build"
  mkdir -p "$CACHE_ROOT"
  find "$CACHE_ROOT" -maxdepth 1 -type d -name 'uup-*' ! -name "uup-$build" -exec rm -rf {} + 2>/dev/null || true
  mkdir -p "$workdir"
  echo "==> Fetching the UUP download package + converting to ISO (multi-GB; resumes if interrupted)" >&2
  # The autodl=2 convert package (the ZIP holding uup_download_macos.sh + the
  # aria2 download list) is served ONLY by the front-end host uupdump.net — the
  # api host returns 400 UNSUPPORTED_COMBINATION for this query. edition stays
  # lowercase ('professional'); that's what the www ZIP route accepts.
  uup_curl "$workdir/uup.zip" \
    "$UUP_WWW/get.php?id=$uuid&pack=en-us&edition=professional&arch=arm64&autodl=2&updates=$UPDATES" \
    || die "couldn't download the UUP package for $uuid after retries (host $UUP_WWW)."
  # Guard: a JSON error/manifest body is not a ZIP — fail loudly before unzip.
  unzip -tq "$workdir/uup.zip" >/dev/null 2>&1 \
    || die "downloaded package isn't a valid ZIP (got $(file -b "$workdir/uup.zip")); UUP dump may have rate-limited or changed hosts."
  ( cd "$workdir" && unzip -oq uup.zip )
  local conv
  conv="$workdir/uup_download_macos.sh"
  [[ -f "$conv" ]] || conv="$workdir/convert.sh"
  [[ -f "$conv" ]] || die "UUP package didn't contain a macOS convert script — convert manually, then re-run with --iso."
  chmod +x "$conv"
  # aria2 -c (in the convert script) resumes the partial download in UUPs/; the
  # convert (CPU-bound) re-runs from the now-complete packages. So a transient
  # upstream blip is RETRYABLE — re-running continues from the partial download
  # rather than restarting the ~8 GB. Seen in the field: git.uupdump.net returned
  # HTTP 522 (Cloudflare origin timeout) on one converter plugin file, which
  # aborted the whole ~30-40 min build. Retry a few times with backoff before
  # giving up; a persistent failure still surfaces via `die`.
  local conv_name; conv_name="$(basename "$conv")"
  local conv_ok=0 attempt delay
  for attempt in 1 2 3; do
    if ( cd "$workdir" && "./$conv_name" ); then conv_ok=1; break; fi
    if [[ "$attempt" -lt 3 ]]; then
      delay=$((attempt * 20))
      echo "    ISO conversion failed (attempt $attempt/3) — likely a transient UUP-dump/network blip; retrying in ${delay}s (aria2 -c resumes the partial download)…" >&2
      sleep "$delay"
    fi
  done
  [[ "$conv_ok" -eq 1 ]] || die "ISO conversion failed after 3 attempts (see output above). If git.uupdump.net is down (HTTP 5xx), wait and rebuild later — the partial download is cached and resumes."
  # -iname folds .iso/.ISO into ONE branch (the duplicated -maxdepth on each side
  # of -o was fragile, since -maxdepth is a global option, not a per-branch test),
  # and `sort` makes the pick deterministic if the converter ever leaves more than
  # one ISO (filesystem order is otherwise unspecified).
  ISO="$(find "$workdir" -maxdepth 1 -iname '*.iso' | sort | head -n1)"
  [[ -n "$ISO" && -f "$ISO" ]] || die "converter finished but produced no ISO in $workdir."
  NEED_REMASTER=1
  echo "==> Built ISO: $ISO" >&2
}

# --- Resumable-build paths ---------------------------------------------------
# The no-prompt boot ISO is cached at $ISO_CACHE, tagged with the build id in
# BOTH $ISO_BUILD_MARKER and $ISO_NOPROMPT_MARKER. The second marker prevents a
# pre-cleanup prompting ISO cache from being reused after no-prompt became
# mandatory. The multi-GB UUP download lives under $CACHE_ROOT and PERSISTS
# across a failed run, so a retry resumes (aria2 -c) instead of re-downloading
# ~8 GB. All of this is reaped only after a FULLY successful build (see the
# fusion arm), so "continue on the latest step" is the default on retry.
MACTIONS_ROOT="${HOME}/.mactions"
ISO_CACHE="$MACTIONS_ROOT/win11-base.iso"
ISO_BUILD_MARKER="$MACTIONS_ROOT/win11-base.iso.build"
ISO_NOPROMPT_MARKER="$MACTIONS_ROOT/win11-base.iso.noprompt"
CACHE_ROOT="$MACTIONS_ROOT/cache"
NEED_REMASTER=1   # 1 = (re)build the no-prompt ISO; 0 = reuse the cached one (resumed)

if [[ -z "$ISO" ]]; then
  auto_download_iso
else
  [[ -f "$ISO" ]] || die "ISO not found at: $ISO"
  # User-supplied ISO: try to record its build id from the filename if present,
  # else leave the recorded build empty (the app's auto-update check treats an
  # empty recorded build as "an update is available" until you rebuild).
  RECORDED_BUILD="$(printf '%s' "$(basename "$ISO")" | grep -Eo '[0-9]{5}\.[0-9]+' | head -n1 || true)"
fi

# --- Build the autounattend media -------------------------------------------
# Windows Setup auto-reads autounattend.xml from removable media. We also place
# bootstrap.ps1 under \setup; autounattend.xml's FirstLogonCommands SCANS every
# drive root for \setup\bootstrap.ps1 (the unattend media's drive letter isn't
# predictable) and runs the first match — so provisioning finds it regardless of
# whether the media mounts as D:, E:, …
#
# An ISO9660 disc the Fusion base build attaches as a SATA cdrom (sata0:1).
build_unattend_iso() {
  # The staging dir is created + tracked by the PARENT (see the call site) so the
  # top-level EXIT trap can reap it on a mid-build interrupt — a var assigned in
  # this $(...) command-substitution subshell would NOT propagate to the parent.
  local staging="$1" out
  out="${TMPDIR:-/tmp}/mactions-unattend.iso"
  mkdir -p "$staging/setup"
  cp "$HERE/autounattend.xml" "$staging/autounattend.xml"
  cp "$HERE/bootstrap.ps1"    "$staging/setup/bootstrap.ps1"
  # -ov + an explicit rm so a re-run is idempotent; without it makehybrid aborts
  # with "already exists" / "Bad file descriptor" when a prior ISO is present.
  rm -f "$out"
  hdiutil makehybrid -ov -iso -joliet -default-volume-name UNATTEND \
    -o "$out" "$staging" >/dev/null
  rm -rf "$staging"
  echo "$out"
}

# Re-master the Win11 install ISO so EFI boot doesn't stop on Microsoft's
# "Press any key to boot from CD" prompt (cdboot). The source ISO ships
# efisys_noprompt.bin next to efisys.bin; we rebuild the El Torito EFI boot image
# from the no-prompt variant with xorriso. This is a required part of the Fusion
# base build: no prompting/manual boot fallback is supported.
make_noprompt_iso() {
  # The source-ISO mountpoint is created + tracked by the PARENT (see the call
  # site) so the top-level EXIT trap can detach+remove it on a mid-remaster
  # interrupt — a var assigned in this $(...) subshell would NOT reach the parent.
  local src="$1" mnt="$2" out vol
  if ! command -v xorriso >/dev/null 2>&1; then
    die "xorriso not installed. Install it with: brew install xorriso"
  fi
  out="${MACTIONS_ROOT}/win11-base.iso"
  if ! hdiutil attach -nobrowse -readonly -mountpoint "$mnt" "$src" >/dev/null 2>&1; then
    rmdir "$mnt" 2>/dev/null || true
    die "couldn't mount $src for the required no-prompt ISO remaster"
  fi
  if [[ ! -f "$mnt/efi/microsoft/boot/efisys_noprompt.bin" ]]; then
    hdiutil detach "$mnt" >/dev/null 2>&1 || true; rmdir "$mnt" 2>/dev/null || true
    die "no efisys_noprompt.bin in $src; cannot build the required no-prompt ISO"
  fi
  vol="$(/usr/sbin/diskutil info "$mnt" 2>/dev/null | sed -n 's/.*Volume Name: *//p' | head -1)"
  [[ -n "$vol" ]] || vol="CCCOMA_X64FRE"
  vol="${vol:0:16}"   # Joliet volid limit is 16 chars (a longer one warns + can abort)
  rm -f "$out"
  echo "    remastering no-prompt ISO with xorriso (multi-GB copy; one-time)..." >&2
  # iso-level 3 (install.wim < 4 GB), Joliet + Rock Ridge, El Torito EFI boot
  # from efisys_noprompt.bin (platform efi, no emulation) — mirrors the source's
  # UEFI-only boot (ARM has no BIOS boot entry). The source ships its own
  # boot.catalog; EXCLUDE it (-m) and regenerate (-c) or xorriso aborts grafting
  # the reserved catalog path. Validate the EFI El Torito entry landed.
  if xorriso -as mkisofs \
       -iso-level 3 -J -joliet-long -R -V "$vol" \
       -m boot.catalog -c boot.catalog \
       -eltorito-platform efi \
       -eltorito-boot efi/microsoft/boot/efisys_noprompt.bin -no-emul-boot \
       -o "$out" "$mnt" >/dev/null 2>&1 \
     && [[ -s "$out" ]] \
     && xorriso -indev "$out" -report_el_torito plain 2>/dev/null | grep -qi 'efi'; then
    hdiutil detach "$mnt" >/dev/null 2>&1 || true; rmdir "$mnt" 2>/dev/null || true
    echo "$out"
  else
    rm -f "$out"; hdiutil detach "$mnt" >/dev/null 2>&1 || true; rmdir "$mnt" 2>/dev/null || true
    die "xorriso remaster/validation failed; no prompting ISO fallback is supported"
  fi
}

echo "==> Building unattended-install ISO (autounattend.xml + bootstrap.ps1)"
# Create the staging dir in the PARENT (not inside the $(...) subshell) so the
# top-level EXIT trap reaps it even if interrupted mid-build.
UNATTEND_STAGING="$(mktemp -d)"
UNATTEND_ISO="$(build_unattend_iso "$UNATTEND_STAGING")"
echo "    $UNATTEND_ISO"

# NOTE: windows-base.build (the recorded build id the app's auto-update check
# reads) is written AFTER the base build SUCCEEDS — see the fusion arm below.
# Recording it here, before the headless install, meant a failed build left a
# recorded build for an image that was never produced (so the app would report
# "up to date" against a base that doesn't exist).

echo
echo "Tool:        $TOOL"
echo "Base VM:     $NAME"
echo "Win11 ISO:   $ISO"
echo "Win11 build: ${RECORDED_BUILD:-unknown}"
echo "Unattend:    $UNATTEND_ISO"
echo "Disk/RAM/CPU: ${DISK_GB}GB / ${RAM_MB}MB / ${CPUS}"
echo

case "$TOOL" in
  fusion)
    # VMware Fusion: fully automated, headless base build via vmrun (the PROVEN
    # Win11-ARM backend). Stash the unattend ISO + a NO-PROMPT remaster of the
    # Win11 ISO at the canonical paths fusion-windows-base reads, then run it
    # (authors the .vmx with a vmxnet3 NIC, boots headless, lets autounattend +
    # bootstrap run — bootstrap installs VMware Tools then the runner agent —
    # then snapshots "base-provisioned").
    echo "==> Stashing unattend ISO at the canonical path for the Fusion base build"
    cp -f "$UNATTEND_ISO" "$MACTIONS_ROOT/mactions-unattend.iso"
    if [[ "$NEED_REMASTER" == 1 ]]; then
      echo "==> Preparing the Win11 boot ISO (no-prompt remaster so there's no boot keypress)"
      # Create the mountpoint in the PARENT (not inside the $(...) subshell) so the
      # top-level EXIT trap detaches+reaps it even if interrupted mid-remaster.
      NOPROMPT_MNT="$(mktemp -d)"
      NOPROMPT_ISO="$(make_noprompt_iso "$ISO" "$NOPROMPT_MNT")"
      # Tag the cached ISO with its build and no-prompt provenance — written ONLY
      # now that the ISO is in place, so a retry's resume check can never reuse a
      # stale/partial/prompting ISO.
      # Guarded like windows-base.build below: a user --iso with no version in its
      # filename leaves RECORDED_BUILD empty, and an empty tag would be a pointless
      # file (the resume check only runs on the auto path, where it's never empty).
      if [[ -n "$RECORDED_BUILD" ]]; then
        printf '%s\n' "$RECORDED_BUILD" > "$ISO_BUILD_MARKER"
        printf '%s\n' "$RECORDED_BUILD" > "$ISO_NOPROMPT_MARKER"
      fi
    else
      echo "==> Reusing the cached no-prompt Win11 ISO for build ${RECORDED_BUILD:-?} (resumed)"
    fi
    echo "==> Running VMware Fusion headless base build (autounattend -> bootstrap -> snapshot)"
    NAME="$NAME" DISK_GB="$DISK_GB" RAM_MB="$RAM_MB" CPUS="$CPUS" \
      WIN11_ISO="$ISO_CACHE" \
      UNATTEND_ISO="$MACTIONS_ROOT/mactions-unattend.iso" \
      "$HERE/fusion-windows-base"
    # Build SUCCEEDED (set -e: a failed fusion-windows-base would have aborted the
    # script before here — it verifies the provisioning sentinel + snapshot before
    # exiting 0). Record the build id the app's auto-update check trusts, then
    # reclaim the multi-GB UUP download cache — the base VM + snapshot are the
    # durable artifacts now, so the raw UUP packages aren't needed. (win11-base.iso
    # + its build tag are KEPT so a future same-build rebuild still skips the
    # download.)
    if [[ -n "${RECORDED_BUILD:-}" ]]; then
      mkdir -p "$MACTIONS_ROOT"
      printf '%s\n' "$RECORDED_BUILD" > "$MACTIONS_ROOT/windows-base.build"
    fi
    # Provisioning-recipe version — written UNCONDITIONALLY (unlike the OS build
    # id, the recipe is always known and always relevant: even a user --iso with
    # no parseable build still baked in the CURRENT bootstrap recipe). The app
    # compares this to WindowsImage.currentProvisioningRecipeVersion to flag a base
    # that predates a rebuild-worthy bootstrap change (e.g. the bash/PortableGit fix).
    mkdir -p "$MACTIONS_ROOT"
    printf '%s\n' "$PROVISIONING_RECIPE_VERSION" > "$MACTIONS_ROOT/windows-base.recipe"
    rm -rf "$CACHE_ROOT" 2>/dev/null || true
    echo
    echo "==> Fusion base build done. Base lives at ~/.mactions/fusion/$NAME.vmx"
    echo "    (snapshot 'base-provisioned'). Per job, mactions-fusion-vm linked-clones"
    echo "    it into ~/.mactions/fusion/<id>/ and attaches a config.iso CD."
    ;;
  *)
    # Unreachable: TOOL was validated to be exactly "fusion" above. Defensive arm
    # so a future backend added to --tool without a dispatch arm fails loudly
    # instead of printing "Done" with no VM built.
    die "internal: no base-build dispatch for tool '$TOOL'"
    ;;
esac

echo
echo "Done. Once the base VM '$NAME' is built + powered off, Mactions can clone it per job."
