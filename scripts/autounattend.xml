<?xml version="1.0" encoding="utf-8"?>
<!--
  autounattend.xml — unattended Windows 11 ARM64 install for a Mactions
  ephemeral GitHub Actions runner base image.

  Windows Setup reads this automatically when it is present on removable media
  (a small ISO/floppy mounted alongside the install media). It:
    - wipes disk 0 and lays down a UEFI/GPT layout (EFI + MSR + Windows),
    - installs the "Windows 11 Pro" Arm64 edition from the multi-edition ISO,
    - creates a local admin `runner` with auto-login and skips all OOBE,
    - runs bootstrap.ps1 on first logon (VMware Tools + the win-arm64 runner
      agent + the MactionsRunOnce task — headless/outbound, no inbound SSH).

  IMPORTANT — THROWAWAY ONLY:
    - The password below is a well-known throwaway value. This VM is destroyed
      after every job; never reuse this image or password for anything real.
    - The product key VK7JG-... is Microsoft's public generic Win11 Pro key
      (selects the edition during Setup; it does NOT activate). The VM runs
      unactivated with cosmetic nags — acceptable for a disposable CI guest.

  Generated/edited from the research brief's skeleton. processorArchitecture
  MUST be arm64 for a Win11-ARM install — an x64/amd64 answer file will fail
  partitioning on Apple Silicon.
-->
<unattend xmlns="urn:schemas-microsoft-com:unattend">
  <settings pass="windowsPE">
    <component name="Microsoft-Windows-International-Core-WinPE"
               processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS">
      <SetupUILanguage><UILanguage>en-US</UILanguage></SetupUILanguage>
      <InputLocale>0409:00000409</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
      <UILanguageFallback>en-US</UILanguageFallback>
    </component>
    <component name="Microsoft-Windows-Setup"
               processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS">
      <!--
        Win11 hardware-requirement bypass. Setup runs the compatibility gate very
        early in windowsPE; without these LabConfig keys it halts at the blue
        "This PC can't run Windows 11" page and the unattended install hangs
        forever. HKLM\SYSTEM\Setup\LabConfig is the live WinPE Setup hive the
        check reads. Required for an Apple-Silicon VM guest (no real TPM 2.0 /
        Secure Boot). wcm is declared inline because it isn't in scope here.
      -->
      <RunSynchronous xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Path>reg add HKLM\SYSTEM\Setup\LabConfig /v BypassTPMCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>2</Order>
          <Path>reg add HKLM\SYSTEM\Setup\LabConfig /v BypassSecureBootCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>3</Order>
          <Path>reg add HKLM\SYSTEM\Setup\LabConfig /v BypassRAMCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>4</Order>
          <Path>reg add HKLM\SYSTEM\Setup\LabConfig /v BypassCPUCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>5</Order>
          <Path>reg add HKLM\SYSTEM\Setup\LabConfig /v BypassStorageCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
      </RunSynchronous>
      <DiskConfiguration>
        <Disk wcm:action="add" xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
          <DiskID>0</DiskID>
          <WillWipeDisk>true</WillWipeDisk>
          <CreatePartitions>
            <!-- UEFI/GPT layout for ARM: EFI System + MSR + Windows. -->
            <CreatePartition wcm:action="add">
              <Order>1</Order><Type>EFI</Type><Size>200</Size>
            </CreatePartition>
            <CreatePartition wcm:action="add">
              <Order>2</Order><Type>MSR</Type><Size>16</Size>
            </CreatePartition>
            <CreatePartition wcm:action="add">
              <Order>3</Order><Type>Primary</Type><Extend>true</Extend>
            </CreatePartition>
          </CreatePartitions>
          <ModifyPartitions>
            <ModifyPartition wcm:action="add">
              <Order>1</Order><PartitionID>1</PartitionID><Format>FAT32</Format><Label>System</Label>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>2</Order><PartitionID>2</PartitionID>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>3</Order><PartitionID>3</PartitionID><Format>NTFS</Format><Label>Windows</Label><Letter>C</Letter>
            </ModifyPartition>
          </ModifyPartitions>
        </Disk>
      </DiskConfiguration>
      <ImageInstall>
        <OSImage>
          <InstallTo><DiskID>0</DiskID><PartitionID>3</PartitionID></InstallTo>
          <InstallFrom>
            <!-- Pick the Arm64 edition out of the multi-edition install.wim/esd. -->
            <MetaData wcm:action="add" xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
              <Key>/IMAGE/NAME</Key><Value>Windows 11 Pro</Value>
            </MetaData>
          </InstallFrom>
        </OSImage>
      </ImageInstall>
      <UserData>
        <ProductKey>
          <!-- Generic Win11 Pro edition-select key (does NOT activate). -->
          <Key>VK7JG-NPHTM-C97JM-9MPGT-3V66T</Key>
        </ProductKey>
        <AcceptEula>true</AcceptEula>
      </UserData>
    </component>
  </settings>

  <settings pass="specialize">
    <component name="Microsoft-Windows-Deployment"
               processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <RunSynchronous>
        <!--
          Best-effort skip of the "Let's connect you to a network" OOBE gate. On
          25H2 (build 26200) this key may be ignored — the provisioned LocalAccount
          + AutoLogon below is what actually avoids the MSA/network OOBE; this is
          belt-and-suspenders. NOTE: the 25H2 ConX setup path can still drop into
          interactive OOBE; that handoff is NOT yet live-verified on a real boot.
        -->
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <!--
            Skip the "Let's connect you to a network" OOBE gate. CRITICAL: OOBE reads
            BypassNRO ONLY from HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\OOBE —
            the old SYSTEM\CurrentControlSet\Control\OOBE path (used here previously)
            is a NO-OP, so this never actually skipped the gate. On a headless base
            build the vmxnet3 NIC has no driver until VMware Tools installs at first
            logon (AFTER OOBE), so OOBE always hits the network stage with no link;
            with BypassNRO now honored it takes the offline path deterministically
            instead of racing (the root cause of the intermittent OOBE hang).
            (MS removed bypassnro.cmd in 24H2 but the registry VALUE still works on
            26200-class builds; belt-and-suspenders alongside the LocalAccount below.)
          -->
          <Path>reg add "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\OOBE" /v BypassNRO /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <!--
          Stage bootstrap.ps1 onto C:\setup\ from whichever removable drive holds
          it, so first-logon doesn't depend on the unattend CD still being mounted
          (it can be ejected/relettered post-install). FirstLogonCommands prefers
          C:\setup\ and falls back to a full drive scan.
        -->
        <RunSynchronousCommand wcm:action="add">
          <Order>2</Order>
          <Path>cmd /c md C:\setup 2&gt;nul &amp; for %d in (D E F G H I) do @if exist %d:\setup\bootstrap.ps1 copy /y %d:\setup\bootstrap.ps1 C:\setup\</Path>
        </RunSynchronousCommand>
      </RunSynchronous>
    </component>
  </settings>

  <settings pass="oobeSystem">
    <!--
      Region/keyboard locale for the oobeSystem pass. windowsPE declares
      International-Core too, but on 24H2/25H2 (build 26100/26200) the OOBE
      region + keyboard-layout screens are driven by the oobeSystem locale
      settings — without this component the unattended install can still stop on
      the interactive "Is this the right country or region?" / keyboard screen
      even with a provisioned LocalAccount. Microsoft's automate-OOBE guidance
      lists these as required for full automation.
    -->
    <component name="Microsoft-Windows-International-Core"
               processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS">
      <InputLocale>0409:00000409</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
      <UILanguageFallback>en-US</UILanguageFallback>
    </component>
    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <UserAccounts>
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Name>runner</Name>
            <Group>Administrators</Group>
            <DisplayName>runner</DisplayName>
            <Password><Value>P@ssw0rd-throwaway</Value><PlainText>true</PlainText></Password>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>
      <AutoLogon>
        <Enabled>true</Enabled>
        <Username>runner</Username>
        <LogonCount>999</LogonCount>
        <Password><Value>P@ssw0rd-throwaway</Value><PlainText>true</PlainText></Password>
      </AutoLogon>
      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <!-- The provisioned LocalAccount means no interactive account screen is
             needed; hide it so 24H2/25H2 can't drop into it. -->
        <HideLocalAccountScreen>true</HideLocalAccountScreen>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <ProtectYourPC>3</ProtectYourPC>
        <SkipMachineOOBE>true</SkipMachineOOBE>
        <SkipUserOOBE>true</SkipUserOOBE>
      </OOBE>
      <FirstLogonCommands>
        <!--
          The specialize pass copies bootstrap.ps1 to C:\setup\, so prefer that
          (independent of the unattend CD still being mounted). Fall back to
          scanning every drive root for \setup\bootstrap.ps1 (robust against
          drive-letter shuffle and CD-vs-USB). -ExecutionPolicy Bypass because a
          fresh install's default policy would otherwise block the script.
        -->
        <SynchronousCommand wcm:action="add">
          <Order>1</Order>
          <CommandLine>powershell -NoProfile -ExecutionPolicy Bypass -Command "$s = if (Test-Path 'C:\setup\bootstrap.ps1') { 'C:\setup\bootstrap.ps1' } else { Get-PSDrive -PSProvider FileSystem | ForEach-Object { Join-Path $_.Root 'setup\bootstrap.ps1' } | Where-Object { Test-Path $_ } | Select-Object -First 1 }; if ($s) { &amp; $s } else { Write-Host 'bootstrap.ps1 not found on any drive'; exit 1 }"</CommandLine>
          <Description>Locate + run bootstrap.ps1 from the unattend media (VMware Tools + win-arm64 runner agent + MactionsRunOnce task)</Description>
        </SynchronousCommand>
      </FirstLogonCommands>
    </component>
  </settings>
</unattend>
